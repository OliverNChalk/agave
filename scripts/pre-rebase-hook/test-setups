# Creates `remote/[upstream]/sync/*` branches for the specified remote.  Remove
# should be created separately.  `setup1` and `setup2` will create these
# already, so this function in only useful in tests that want to simulation
# situations with more than one remote.
createRebaseTrackingBranchesFor() {
  if [[ $# -ne 5 ]]; then
    echo "ERROR: createRebaseTrackingBranchesFor takes 5 arguments"
    exit 1
  fi

  local remote=$1
  local date=$2
  local masterUpstream=$3
  local masterLocal=$4
  local master=$5

  gitMockRemoteBranch "$remote" "master" "$master"
  gitMockRemoteBranch "$remote" "sync/master-upstream" "$masterUpstream"
  gitMockRemoteBranch "$remote" "sync/master/upstream/$date" "$masterUpstream"
  gitMockRemoteBranch "$remote" "sync/master-local" "$masterLocal"
  gitMockRemoteBranch "$remote" "sync/master/local/$date" "$masterLocal"
}


